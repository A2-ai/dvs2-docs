#!/usr/bin/env bash
set -e
repo_root=$(cd "$(dirname "$0")/.." && pwd -P)

for candidate in /opt/homebrew/bin/tree /usr/local/bin/tree /usr/bin/tree /bin/tree; do
  if [[ -x "$candidate" ]]; then
    real_tree="$candidate"
    break
  fi
done

if [[ -z "${real_tree:-}" ]]; then
  echo "tree binary not found in standard locations" >&2
  exit 1
fi

exec "$real_tree" --gitfile "$repo_root/.treeignore" "$@"
